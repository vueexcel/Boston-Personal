# PostgreSQL (required) — AWS RDS, EC2 localhost, or Docker
DATABASE_URL=postgresql://bostel_app:CHANGE_ME@localhost:5432/bostel_voice


# Redis (required for live voice — call sessions, BullMQ)
REDIS_URL=redis://localhost:6379

# BullMQ billing period close (worker only). Set BILLING_CLOSE_PERIODS_CRON in prod.
BILLING_JOBS_ENABLED=1
BILLING_CLOSE_PERIODS_CRON=0 6 * * *

# Twilio (REST + webhook validation + Media Streams)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
NEXT_PUBLIC_APP_URL=https://YOUR-PUBLIC-HOST
TWILIO_WEBHOOK_BASE_URL=https://YOUR-PUBLIC-HOST

# --- Local dev (npm run dev + npm run worker) ---
# VOICE_MEDIA_STREAM_PROXY_VIA_APP=0
# TWILIO_MEDIA_STREAM_WSS_URL=wss://YOUR-TUNNEL-TO-3001/twilio/media-stream

# --- Production / single-host WSS (voiceai.bostel.com + npm run start:prod) ---
# VOICE_MEDIA_STREAM_PROXY_VIA_APP=1

# --- Production / split web + worker (see docs/DEPLOY_AWS.md) ---
VOICE_MEDIA_STREAM_PROXY_VIA_APP=0
TWILIO_MEDIA_STREAM_WSS_URL=wss://YOUR-PUBLIC-HOST/twilio/media-stream
VOICE_MEDIA_STREAM_PORT=3001
TWILIO_MEDIA_STREAM_PATH=/twilio/media-stream
# Portal voice test WebSocket path (default /voice/agent-test)
# VOICE_TEST_STREAM_PATH=/voice/agent-test
# VOICE_TEST_STREAM_WSS_URL=wss://YOUR-PUBLIC-HOST/voice/agent-test



# VOICE_BARGE_IN_MIN_CHARS=12
# VOICE_PARTIAL_STABILITY_MIN=0.85
# VOICE_ENDPOINT_SILENCE_MS=1300
# ELEVENLABS_STT_VAD_SILENCE_SECS=2.0
# VOICE_BARGE_IN_ONLY_FINAL=1
# VOICE_POST_ENDPOINT_DELAY_MS=500
# VOICE_ENDPOINT_MIN_CHARS=6
# VOICE_TTS_FRAME_DELAY_MS=23
# ELEVENLABS_STT_MIN_SPEECH_MS=100
# ELEVENLABS_STT_MIN_SILENCE_MS=100


# VOICE_TTS_FRAME_DELAY_MS=10
# VOICE_TTS_SPEED=0.95
# VOICE_TTS_STABILITY=0.5
# VOICE_TTS_SIMILARITY_BOOST=0.75
# VOICE_TTS_STYLE=0
# VOICE_TTS_USE_SPEAKER_BOOST=1
# VOICE_TTS_STREAMING_LATENCY=0
# Soften trailing ! for phone + browser voice test TTS (transcripts unchanged). 1=on (default), 0=off
# VOICE_TTS_SOFTEN_EXCLAMATIONS=1
# VOICE_CALLER_INACTIVITY_SEC=30

# ELEVENLABS_STT_MODEL=scribe_v2_realtime
# ELEVENLABS_STT_AUDIO_FORMAT=ulaw_8000
# ELEVENLABS_STT_VAD_THRESHOLD=0.55

OPENAI_API_KEY=
OPENAI_MODEL=
VOICE_OPENAI_MODEL=gpt-4o-mini

ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
# Browser voice test + preview button (default mp3_44100_128)
# ELEVENLABS_TTS_BROWSER_FORMAT=mp3_44100_128
# Browser voice test uses VOICE_TTS_* settings; Preview voice button uses ElevenLabs defaults
# PSTN phone calls via Twilio Media Streams (default ulaw_8000)
# ELEVENLABS_TTS_TELEPHONY_FORMAT=ulaw_8000
ELEVENLABS_WEBHOOK_SECRET=

# Optional E.164 for routing fallback type BOSTEL_SUPPORT
# BOSTEL_SUPPORT_E164=+16175550100

# PLATFORM_ADMIN_EMAIL=admin@yourcompany.com
# PLATFORM_ADMIN_PASSWORD=change-me-strong-password
# PLATFORM_ADMIN_NAME=Platform Admin


# DEBUG_VOICE=1
# Per-session voice pipeline logs (enabled when DEBUG_VOICE=1 or VOICE_LOG=1)
# VOICE_LOG=1
# VOICE_LOG_DIR=logs/voice
