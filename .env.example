# PostgreSQL (required) — AWS RDS, EC2 localhost, or Docker
DATABASE_URL=postgresql://bostel_app:CHANGE_ME@localhost:5432/bostel_voice
# DATABASE_SSL=1
# DATABASE_SSL_REJECT_UNAUTHORIZED=0
# DATABASE_POOL_MAX=10

# Customer Tenant Portal (optional display defaults)
PORTAL_TENANT_DISPLAY_ID=TEN-10025
PORTAL_ACCOUNT_STATUS=ACTIVE

# Redis (required for live voice — call sessions, BullMQ)
REDIS_URL=redis://localhost:6379

# Twilio (REST + webhook validation + Media Streams)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
NEXT_PUBLIC_APP_URL=https://YOUR-PUBLIC-HOST
TWILIO_WEBHOOK_BASE_URL=https://YOUR-PUBLIC-HOST

# --- Local dev (npm run dev + npm run worker) ---
# VOICE_MEDIA_STREAM_PROXY_VIA_APP=0
# TWILIO_MEDIA_STREAM_WSS_URL=wss://YOUR-TUNNEL-TO-3001/twilio/media-stream
# See docs/VOICE_LOCAL.md

# --- Production / single-host WSS (voiceai.bostel.com + npm run start:prod) ---
# VOICE_MEDIA_STREAM_PROXY_VIA_APP=1

# --- Production / split web + worker (see docs/DEPLOY_AWS.md) ---
VOICE_MEDIA_STREAM_PROXY_VIA_APP=0
TWILIO_MEDIA_STREAM_WSS_URL=wss://YOUR-PUBLIC-HOST/twilio/media-stream
VOICE_MEDIA_STREAM_PORT=3001
TWILIO_MEDIA_STREAM_PATH=/twilio/media-stream

# ElevenLabs Scribe v2 Realtime STT (PSTN calls — requires ELEVENLABS_API_KEY)
# ELEVENLABS_STT_MODEL=scribe_v2_realtime
# ELEVENLABS_STT_AUDIO_FORMAT=ulaw_8000
# ELEVENLABS_STT_VAD_SILENCE_SECS=1.0
# ELEVENLABS_STT_VAD_THRESHOLD=0.4

# Voice tuning (barge-in, endpointing, TTS pace)
# VOICE_PARTIAL_STABILITY_MIN=0.85
# VOICE_BARGE_IN_MIN_CHARS=12
# VOICE_BARGE_IN_ONLY_FINAL=1
# VOICE_ENDPOINT_SILENCE_MS=1000
# VOICE_POST_ENDPOINT_DELAY_MS=300
# VOICE_ENDPOINT_MIN_CHARS=2
# VOICE_TTS_FRAME_DELAY_MS=23
# VOICE_TTS_SPEED=0.9

OPENAI_API_KEY=
OPENAI_MODEL=
VOICE_OPENAI_MODEL=gpt-4o-mini

ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_WEBHOOK_SECRET=

# DEBUG_VOICE=1
