# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Postgres — use service role only on the server for privileged writes)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres URL (migrations, Drizzle, etc.)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Customer Tenant Portal (server-side display until auth/session exists)
PORTAL_TENANT_DISPLAY_ID=TEN-10025
PORTAL_ACCOUNT_STATUS=ACTIVE

# Redis (cache + BullMQ)
REDIS_URL=redis://localhost:6379

# Twilio (REST + webhook validation)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# OpenAI (call summaries, portal text test chat)
OPENAI_API_KEY=
# Optional override; default gpt-4o in code
OPENAI_MODEL=

# ElevenLabs (TTS / voices / Conversational AI — required for Voice test tab)
ELEVENLABS_API_KEY=

# ElevenLabs-style Standard Webhooks signing secret (raw secret from vendor console)
ELEVENLABS_WEBHOOK_SECRET=
