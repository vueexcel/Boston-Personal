{
  "name": "bostonai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:unified": "tsx --env-file=.env server.dev.ts",
    "build": "next build",
    "postbuild": "node scripts/copy-standalone-static.cjs",
    "start": "node .next/standalone/server.js",
    "start:prod": "tsx --env-file=.env server.prod.ts",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "worker": "tsx --env-file=.env src/lib/queue/workers/run.ts",
    "worker:dev": "tsx watch --env-file=.env src/lib/queue/workers/run.ts",
    "db:migrate": "tsx --env-file=.env scripts/db/migrate.ts",
    "twilio:sync-status-callbacks": "tsx --env-file=.env scripts/twilio/sync-voice-status-callbacks.ts"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.46.0",
    "@elevenlabs/react": "^0.12.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "openai": "^6.37.0",
    "pg": "^8.21.0",
    "react": "^18",
    "react-dom": "^18",
    "server-only": "^0.0.1",
    "standardwebhooks": "^1.0.0",
    "tailwind-merge": "^3.6.0",
    "twilio": "^6.0.2",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.5.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
